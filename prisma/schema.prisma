// ─────────────────────────────────────────────────────────────────────────────
// Shree Shyam Bags — Prisma Schema (MongoDB)
// Collections map:
//   users           → admin + customer accounts
//   products        → bag catalog
//   product_images  → cloudinary image URLs per product
//   variants        → size/color/shape SKUs per product
//   pricing_tiers   → bulk kg price slabs per variant
//   cart_items      → customer shopping cart
//   orders          → razorpay orders
//   order_items     → line items inside an order
//   quote_requests  → B2B quote enquiries
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  CREATED
  PAID
  FAILED
  CANCELLED
  SHIPPED
  DELIVERED
}

enum QuoteStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
}

// ── User ──────────────────────────────────────────────────────────────────────
// Stores both CUSTOMER and ADMIN accounts.
// Admin accounts are identified by role = ADMIN.

model User {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  name     String?
  email    String   @unique
  phone    String?
  password String
  role     UserRole @default(CUSTOMER)

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  cartItems CartItem[]

  @@map("users")
}

// ── Product ───────────────────────────────────────────────────────────────────
// Top-level catalog entry. Variants hold the actual SKUs.

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  basePrice   Int?     // stored in paise (₹ × 100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants      Variant[]
  images        ProductImage[]
  quoteRequests QuoteRequest[]

  @@map("products")
}

// ── ProductImage ──────────────────────────────────────────────────────────────
// One product can have many gallery images (Cloudinary URLs).

model ProductImage {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_images")
}

// ── Variant ───────────────────────────────────────────────────────────────────
// A variant is a specific size/color/shape combination of a product.
// B2B pricing is stored in pricePerKg + PricingTier slabs.

model Variant {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])

  size     String
  color    String
  shape    String
  sku      String?
  stock    Int     @default(0)
  isActive Boolean @default(true)

  price      Int  // retail price in paise
  gsm        Int?
  pricePerKg Int? // default B2B price per kg in paise

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricingTiers  PricingTier[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]

  @@index([productId])
  @@map("variants")
}

// ── PricingTier ───────────────────────────────────────────────────────────────
// Bulk pricing slabs: e.g. 200 KG → ₹120/kg, 500 KG → ₹110/kg

model PricingTier {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  variantId String  @db.ObjectId
  variant   Variant @relation(fields: [variantId], references: [id])

  minQtyKg   Int // minimum quantity in KG to get this rate
  pricePerKg Int // price in paise per kg

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variantId])
  @@map("pricing_tiers")
}

// ── CartItem ──────────────────────────────────────────────────────────────────
// Customer cart — same variant + same customText merges (quantity increases).

model CartItem {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String  @db.ObjectId
  user      User    @relation(fields: [userId], references: [id])
  variantId String  @db.ObjectId
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity   Int     @default(1)
  customText String? // printing text on the bag

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, variantId, customText])
  @@index([userId])
  @@map("cart_items")
}

// ── Order ─────────────────────────────────────────────────────────────────────
// Razorpay order with full shipping address snapshot.

model Order {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  status   OrderStatus @default(CREATED)
  subtotal Int         // in paise
  shipping Int         @default(0)
  total    Int         // in paise

  // Shipping address (snapshotted at order time)
  shipName         String
  shipPhone        String
  shipAddressLine1 String
  shipAddressLine2 String?
  shipCity         String
  shipState        String
  shipPincode      String

  // Razorpay
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([userId])
  @@map("orders")
}

// ── OrderItem ─────────────────────────────────────────────────────────────────
// Line items snapshotted at purchase time so product edits don't break history.

model OrderItem {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [id])

  variantId String  @db.ObjectId
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity   Int
  unitPrice  Int    // in paise at time of purchase
  customText String?

  // Snapshotted fields — safe to read even if product/variant changes
  productTitle String
  size         String
  color        String
  shape        String

  @@index([orderId])
  @@map("order_items")
}

// ── QuoteRequest ──────────────────────────────────────────────────────────────
// B2B bulk enquiry from customer (or anonymous user).
// Admin responds with adminPricePerKg + adminNote + status update.

model QuoteRequest {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String? @db.ObjectId
  productId String? @db.ObjectId
  variantId String? @db.ObjectId

  // Customer contact
  name  String
  phone String
  email String?

  // Requirement
  quantityKg  Int     @default(0)
  gsm         Int?
  printing    Boolean @default(false)
  logoUrl     String? // Cloudinary URL of uploaded logo
  message     String?
  enquiryType String  @default("QUOTE")

  // Admin response
  status          QuoteStatus @default(PENDING)
  adminPricePerKg Int?        // in paise per kg
  adminNote       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id])
  variant Variant? @relation(fields: [variantId], references: [id])

  @@index([status])
  @@index([productId])
  @@index([userId])
  @@map("quote_requests")
}
